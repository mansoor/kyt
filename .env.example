# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=teslamate
POSTGRES_USER=teslamate
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://teslamate:changeme@db:5432/teslamate

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-32-char-random-secret-key-here-000000000000
ENCRYPTION_KEY=replace-with-32-char-random-encryption-key-here-000000

# ── Admin user (created on first run if no users exist) ───────────────────────
INITIAL_ADMIN_EMAIL=admin@kyt.local
INITIAL_ADMIN_PASSWORD=changeme

# ── Tesla API (required for Phase 2 data collection) ─────────────────────────
# Register at https://developer.tesla.com — set redirect URI to http://yourdomain/api/tesla/auth/callback
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_REDIRECT_URI=   # optional — auto-detected from request if blank

# ── MQTT (optional — for Home Assistant integration) ──────────────────────────
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Geocoding (optional — defaults to public Photon API) ─────────────────────
GEOCODER_URL=https://photon.komoot.io

# ── General ───────────────────────────────────────────────────────────────────
TZ=UTC
LOG_LEVEL=INFO

# Dev only — comma-separated allowed CORS origins
# CORS_ORIGINS=http://localhost:5173
