{
  # Uncomment to use a real domain with auto HTTPS:
  # email your@email.com
}

# Local HTTP (home server / LAN access without domain)
:80 {
  handle /api/* {
    reverse_proxy backend:8000 {
      # Pass the original protocol through so the backend can build correct URLs
      # when behind Cloudflare or Traefik (which terminate TLS before us).
      header_up X-Forwarded-Proto {http.request.header.X-Forwarded-Proto}
      header_up X-Forwarded-Host {http.request.header.X-Forwarded-Host}
    }
  }

  handle /health {
    reverse_proxy backend:8000
  }

  handle {
    reverse_proxy frontend:3000
  }

  header {
    X-Frame-Options "DENY"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "geolocation=(), camera=(), microphone=()"
    # CSP: allow OSM tiles + unpkg for Leaflet icons, no inline scripts except Vite's
    Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.tile.openstreetmap.org https://unpkg.com; connect-src 'self'; font-src 'self'; frame-ancestors 'none'"
    -Server
  }
}

